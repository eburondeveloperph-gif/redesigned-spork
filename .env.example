# Beatrice Environment Configuration
# Copy this to .env and fill in your values

# Gemini API Key (required)
BEATRICE_GEMINI_API_KEY=your_gemini_api_key_here
BEATRICE_GEMINI_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
BEATRICE_GEMINI_WS_BASE_URL=wss://generativelanguage.googleapis.com/ws
BEATRICE_GEMINI_API_VERSION=v1beta

# Firebase Configuration (for auth and database)
BEATRICE_FIREBASE_API_KEY=
BEATRICE_FIREBASE_AUTH_DOMAIN=
BEATRICE_FIREBASE_DATABASE_URL=
BEATRICE_FIREBASE_PROJECT_ID=
BEATRICE_FIREBASE_STORAGE_BUCKET=
BEATRICE_FIREBASE_MESSAGING_SENDER_ID=
BEATRICE_FIREBASE_APP_ID=
BEATRICE_FIREBASE_MEASUREMENT_ID=

# Google Workspace Tools (requires Firebase auth with Google)
BEATRICE_GOOGLE_TOOLS_ENABLED=true

# Hermes Agent (optional - for enhanced AI capabilities)
BEATRICE_HERMES_ENABLED=false
BEATRICE_HERMES_ENDPOINT=
BEATRICE_HERMES_USERNAME=
BEATRICE_HERMES_PASSWORD=
BEATRICE_HERMES_ACCESS_TOKEN=

# Memory Base URL (optional - for persistent memory)
BEATRICE_MEMORY_BASE_URL=
BEATRICE_MEMORY_SEARCH_TIMEOUT_MS=200
